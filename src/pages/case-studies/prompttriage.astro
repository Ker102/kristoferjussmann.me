				padding: 0;
				border: 0;
				background: transparent;
				color: inherit;
				font: inherit;
				text-align: left;
				cursor: zoom-in;
			}

			.image-open:hover img,
			.image-open:focus-visible img {
				border-color: rgba(150, 154, 164, 0.52);
				box-shadow: 0 18px 42px rgba(0, 0, 0, 0.16);
			}

			.image-open:focus-visible {
				border-radius: 18px;
				outline: 2px solid rgba(156, 163, 175, 0.72);
				outline-offset: 4px;
			}

			.image-modal {
				width: min(96vw, 1180px);
				max-height: min(92vh, 920px);
				padding: 0;
				border: 1px solid rgba(255, 255, 255, 0.18);
				border-radius: 28px;
				background:
					linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(235, 236, 240, 0.88)),
					var(--theme-bg);
				color: var(--theme-text);
				box-shadow: 0 32px 100px rgba(0, 0, 0, 0.34);
				overflow: hidden;
			}

			.image-modal::backdrop {
				background: rgba(0, 0, 0, 0.72);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
			}

			:global([data-mode="dark"]) .image-modal {
				background:
					linear-gradient(145deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.035)),
					#050505;
				border-color: rgba(255, 255, 255, 0.18);
			}

			.modal-shell {
				display: grid;
				gap: 0.8rem;
				padding: 0.8rem;
			}

			.modal-bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 0.2rem 0.3rem;
			}

			.modal-bar h3 {
				margin: 0;
				font-size: 1rem;
				letter-spacing: 0;
			}

			.modal-close {
				min-height: 38px;
				padding: 0.55rem 0.8rem;
				border-radius: 999px;
				border: 1px solid var(--theme-border);
				background: var(--chrome-ink);
				color: var(--chrome-paper);
				font: inherit;
				font-weight: 800;
				cursor: pointer;
			}

			:global([data-mode="dark"]) .modal-close {
				background: #f5f5f5;
				color: #050505;
			}

			.modal-image {
				width: 100%;
				max-height: 76vh;
				object-fit: contain;
				border-radius: 20px;
				background: #ffffff;
				border: 1px solid var(--theme-border);
			}

			.media-note {
				margin: 1.25rem 0;
				padding: 1rem;
				border-radius: 22px;
				border: 1px dashed rgba(120, 124, 132, 0.34);
				background: rgba(255, 255, 255, 0.08);
				color: var(--muted-text);
				line-height: 1.55;
			}

			.architecture-system {
				grid-template-columns: 1fr;
				align-items: stretch;
			}

			.PromptTriageArchitecture {
				position: relative;
			}

			.architecture-export {
				display: grid;
				gap: 0.85rem;
				margin: 1rem 0 1.5rem;
				padding: 1rem;
				border: 1px solid var(--theme-border);
				border-radius: 24px;
				background:
					linear-gradient(145deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.22)),
					var(--glass-surface);
			}

			:global([data-mode="dark"]) .architecture-export {
				background:
					linear-gradient(145deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.025)),
					#080808;
				border-color: rgba(255, 255, 255, 0.14);
			}

			.architecture-export img {
				width: 100%;
				border-radius: 18px;
				border: 1px solid var(--theme-border);
				background: #050505;
			}

			.architecture-export figcaption {
				color: var(--muted-text);
				line-height: 1.55;
			}

			.architecture-lane {
				display: grid;
				align-content: start;
				gap: 0.75rem;
				min-height: 100%;
			}

			.architecture-lane h3 {
				color: var(--heading-color);
			}

			.architecture-list {
				display: grid;
				gap: 0.5rem;
			}

			.architecture-node {
				min-height: 44px;
				padding: 0.72rem 0.8rem;
				border-radius: 14px;
				background: rgba(16, 16, 16, 0.92);
				color: #fff;
				font-size: 0.86rem;
				font-weight: 750;
				line-height: 1.25;
			}

			.architecture-lane:nth-child(even) .architecture-node {
				background: rgba(255, 255, 255, 0.16);
				color: var(--heading-color);
				border: 1px solid var(--theme-border);
			}

			.section-subhead {
				display: grid;
				gap: 0.35rem;
				margin: 2rem 0 0.85rem;
			}

			.section-subhead h3 {
				margin: 0;
				font-size: clamp(1.25rem, 5vw, 1.85rem);
				letter-spacing: 0;
			}

			.section-subhead p {
				margin: 0;
				max-width: 760px;
				color: var(--muted-text);
				line-height: 1.6;
			}

			.security-table-wrap {
				width: 100%;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
			}

			.security-table {
				width: 100%;
				min-width: 720px;
				border-collapse: collapse;
			}

			.security-table th,
			.security-table td {
				padding: 0.85rem;
				border-bottom: 1px solid var(--theme-border);
				color: var(--muted-text);
				font-size: 0.9rem;
				line-height: 1.45;
				text-align: left;
				vertical-align: top;
			}

			.security-table th {
				color: var(--heading-color);
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.deployment-steps {
				counter-reset: deploy-step;
			}

			.deployment-steps li {
				position: relative;
				display: grid;
				gap: 0.2rem;
				padding: 0.9rem 1rem 0.9rem 3rem;
				border-radius: 18px;
				background: var(--glass-surface);
				border: 1px solid var(--theme-border);
				color: var(--muted-text);
				line-height: 1.45;
			}

			.deployment-steps li::before {
				counter-increment: deploy-step;
				content: counter(deploy-step);
				position: absolute;
				left: 0.9rem;
				top: 0.85rem;
				display: grid;
				place-items: center;
				width: 1.5rem;
				height: 1.5rem;
				border-radius: 999px;
				background: #101010;
				color: #fff;
				font-size: 0.75rem;
				font-weight: 800;
			}

			.evidence-needed {
				margin: 1.5rem 0 0;
				border-color: rgba(120, 124, 132, 0.24);
				background: var(--glass-surface);
			}

			.evidence-needed summary {
				cursor: pointer;
				color: var(--heading-color);
				font-weight: 800;
			}

			.evidence-needed summary::marker {
				color: var(--chrome-silver);
			}

			.evidence-needed ul {
				margin-bottom: 0;
				padding-top: 0.35rem;
			}

			.evidence-needed li {
				padding-left: 0.85rem;
				border-left: 3px solid rgba(120, 124, 132, 0.28);
			}

			.template-grid,
			.project-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0.9rem;
			}

			.section-card,
			.project-card,
			.pipeline,
			.cta-panel {
				border-radius: 24px;
				padding: 1rem;
			}

			.section-card h3 {
				font-size: 1.05rem;
				margin: 0 0 0.55rem;
			}

			.section-card p,
			.project-card p,
			.pipeline li,
			.cta-panel p {
				margin: 0;
				color: var(--muted-text);
				line-height: 1.6;
			}

			.project-card {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				transition:
					transform 220ms var(--ease-apple),
					box-shadow 220ms var(--ease-apple),
					background 220ms var(--ease-apple);
			}

			.project-card:hover {
				transform: translateY(-4px);
				background: var(--glass-surface-hover);
				box-shadow: 0 22px 56px rgba(30, 41, 59, 0.12);
			}

			.project-meta {
				color: var(--muted-text);
				font-size: 0.9rem;
				font-weight: 700;
			}

			.stack-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
			}

			.stack-list span {
				padding: 0.32rem 0.6rem;
				border-radius: 999px;
				background: rgba(120, 124, 132, 0.14);
				color: var(--heading-color);
				font-size: 0.78rem;
				font-weight: 700;
			}

			.text-link {
				display: inline-flex;
				align-items: center;
				min-height: 36px;
				color: var(--heading-color);
				font-weight: 800;
				text-decoration: none;
			}

			.text-link:hover,
			.text-link:focus-visible {
				text-decoration: underline;
				text-underline-offset: 4px;
			}

			.pipeline ul {
				display: grid;
				gap: 0.75rem;
				padding: 0;
				margin: 0;
			}

			.pipeline li {
				padding-left: 1rem;
				border-left: 3px solid rgba(120, 124, 132, 0.3);
			}

			.cta-panel {
				display: grid;
				gap: 1rem;
				margin-top: 3rem;
				background: var(--chrome-dark-gradient);
				color: #fff;
			}

			.cta-panel h2 {
				margin: 0;
				color: #fff;
				letter-spacing: 0;
			}

			.cta-panel p {
				color: rgba(255, 255, 255, 0.74);
			}

			.cta-panel .button.secondary {
				background: rgba(255, 255, 255, 0.1);
				color: #fff;
				border-color: rgba(255, 255, 255, 0.18);
			}

			@media (min-width: 640px) {
				main.case-study-page {
					padding-inline: 1.5rem;
				}

				.trust-strip,
				.metric-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.article-grid,
				.research-summary-grid,
				.research-gallery,
				.cost-grid,
				.benchmark-grid,
				.technique-grid,
				.gap-grid,
				.edge-case-grid,
				.template-status-grid,
				.architecture-system {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}

			@media (min-width: 900px) {
				main.case-study-page {
					padding-top: 9rem;
				}

				.hero {
					gap: 1.5rem;
					padding-bottom: 3rem;
				}

				.trust-strip {
					grid-template-columns: repeat(4, minmax(0, 1fr));
				}

				.featured-header {
					grid-template-columns: minmax(0, 1fr) 320px;
					align-items: end;
				}

				.metric-grid,
				.research-summary-grid,
				.project-grid {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}

				.research-gallery {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}

				.cost-grid {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}

				.benchmark-grid {
					grid-template-columns: repeat(4, minmax(0, 1fr));
				}

				.technique-grid,
				.gap-grid,
				.edge-case-grid,
				.template-status-grid {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}

				.architecture-system {
					grid-template-columns: repeat(5, minmax(0, 1fr));
				}

				.benchmark-impact-table table {
					display: table;
					width: 100%;
					border-collapse: collapse;
				}

				.benchmark-impact-table thead {
					position: static;
					width: auto;
					height: auto;
					overflow: visible;
					clip: auto;
					white-space: normal;
				}

				.benchmark-impact-table tbody {
					display: table-row-group;
				}

				.benchmark-impact-table tr {
					display: table-row;
					padding: 0;
					border: 0;
					background: transparent;
				}

				.benchmark-impact-table th,
				.benchmark-impact-table td {
					display: table-cell;
					padding: 0.75rem;
					border-bottom: 1px solid var(--theme-border);
					text-align: left;
					vertical-align: top;
				}

				.benchmark-impact-table th {
					color: var(--heading-color);
					font-size: 0.78rem;
					letter-spacing: 0.05em;
					text-transform: uppercase;
				}

				.benchmark-impact-table td::before {
					content: none;
				}

				.template-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.cta-panel {
					grid-template-columns: minmax(0, 1fr) auto;
					align-items: center;
					padding: 2rem;
				}
			}

			@media (min-width: 1100px) {
				.template-grid {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}
			}

			@media (prefers-reduced-motion: reduce) {
				* {
					transition-duration: 0.01ms !important;
					animation-duration: 0.01ms !important;
					animation-iteration-count: 1 !important;
				}

				.button:hover,
				.button:focus-visible,
				.project-card:hover,
				.article-card:hover,
				.research-card:hover,
				.media-card:hover {
					transform: none;
				}
			}
		</style>
	</head>
	<body data-theme="clean">
		<Header />
		<main class="case-study-page">
			<section class="hero">
				<span class="eyebrow">Complete case study</span>
				<h1>PromptTriage Case Study</h1>
				<p>
					A structured, evidence-backed page for the PromptTriage app, research studies,
					architecture, deployment history, Azure ML costs, tradeoffs, and remaining proof gaps.
				</p>
				<div class="hero-actions">
					<a class="button primary" href="#prompttriage">Read the case study</a>
					<a class="button secondary" href="/case-studies">Back to case studies</a>
				</div>
			</section>

			<section class="trust-strip" aria-label="Evidence categories">
				<div class="trust-item">
					<strong>Systems</strong>
					<span>Working software, demos, and repositories.</span>
				</div>
				<div class="trust-item">
					<strong>Research</strong>
					<span>Benchmarks, evaluation notes, and costs.</span>
				</div>
				<div class="trust-item">
					<strong>Operations</strong>
					<span>Deployment, logging, runbooks, and failure modes.</span>
				</div>
				<div class="trust-item">
					<strong>Hiring signal</strong>
					<span>Fast summaries with links to deeper evidence.</span>
				</div>
			</section>

			<section id="prompttriage" class="featured">
				<div class="featured-header">
					<div>
						<span class="status">Complete case study</span>
						<h2>PromptTriage</h2>
						<p class="featured-summary">
							RAG-powered prompt engineering platform with a documented research trail,
							modality-specific optimization, and a public demo.
						</p>
					</div>
					<div class="card-actions">
						<a class="button primary" href="https://prompttriage.kaelux.dev" target="_blank" rel="noopener noreferrer">Live demo</a>
						<a class="button secondary" href="https://github.com/Ker102/PromptTriage" target="_blank" rel="noopener noreferrer">Repository</a>
						<a class="button secondary" href="/downloads/prompttriage-case-study.pdf" target="_blank" rel="noopener noreferrer">Download PDF</a>
					</div>
				</div>

				<div class="metric-grid" aria-label="PromptTriage evidence metrics">
					<div class="metric">
						<strong>28K+</strong>
						<span>Prompt corpus referenced in local project evidence.</span>
					</div>
					<div class="metric">
						<strong>4</strong>
						<span>Prompt modalities: text, image, video, and system prompts.</span>
					</div>
					<div class="metric">
						<strong>L1</strong>
						<span>Naive RAG was the strongest documented retrieval strategy.</span>
					</div>
					<div class="metric">
						<strong>5+</strong>
						<span>Completed research studies covering model, RAG, format, and judge behavior.</span>
					</div>
					<div class="metric">
						<strong>+13.9%</strong>
						<span>Best relative instruction-following gain versus a generic prompt.</span>
					</div>
					<div class="metric">
						<strong>86.7%</strong>
						<span>Fewer prompt words in the short-prompt Study E condition versus long prompts.</span>
					</div>
				</div>

				<section class="benchmark-impact" aria-label="PromptTriage benchmark impact metrics">
					<div class="section-subhead">
						<h3>Benchmark impact</h3>
						<p>
							The metrics below separate different kinds of value: downstream output quality,
							retrieval orchestration cost, model/runtime choice, and prompt-length efficiency.
							That keeps the case study honest about what each percentage actually measures.
						</p>
					</div>
					<div class="benchmark-impact-panel">
						<div class="benchmark-impact-table">
							<table>
								<thead>
									<tr>
										<th>Metric</th>
										<th>Scope</th>
										<th>Result</th>
										<th>Impact</th>
										<th>Interpretation</th>
									</tr>
								</thead>
								<tbody>
									{benchmarkImpactRows.map((row) => (
										<tr>
											<td data-label="Metric" class="impact-name">{row.metric}</td>
											<td data-label="Scope">{row.scope}</td>
											<td data-label="Result">{row.result}</td>
											<td data-label="Impact" class="edge-case-delta">{row.impact}</td>
											<td data-label="Interpretation">{row.note}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</div>
					<p class="prompt-order-note">
						Honorable mention: the research also supports a practical prompt-engineering rule for
						multimodal and agentic workflows. Important instructions should be front-loaded, with
						role, constraints, input priority, output format, and safety boundaries ordered from
						most important to least important. Models react differently to token order, so how
						context is fed to the model can matter as much as the wording itself.
					</p>
				</section>

				<section class="edge-case-section" aria-label="Edge cases where PromptTriage helped most">
					<div class="section-subhead">
						<h3>Edge cases where PromptTriage mattered most</h3>
						<p>
							The largest gains appeared when the task punished default model behavior: strict
							format constraints, anti-trend design instructions, timezone reasoning, domain
							boundaries, security review, and exact instruction following.
						</p>
					</div>
					<div class="edge-case-grid">
						{edgeCaseWins.map((edgeCase) => (
							<article class="edge-case-card">
								<small>{edgeCase.category}</small>
								<h3>{edgeCase.bestWin}</h3>
								<p>{edgeCase.task}</p>
								<p class="edge-case-delta">{edgeCase.delta}</p>
								<p>{edgeCase.whyItMatters}</p>
							</article>
						))}
					</div>
				</section>

				<section class="research-program" aria-label="PromptTriage research program summary">
					<div class="section-subhead">
						<h3>Research program summary</h3>
						<p>
							PromptTriage was built around several connected studies, not a single benchmark.
							The public articles cover the most readable findings, while the local research
							logs preserve model, RAG, judge-bias, and stopped/resumed run details.
						</p>
					</div>
					<div class="research-summary-grid">
						{researchProgram.map((study) => (
							<article class="research-study-card">
								<div class="research-study-top">
									<span>{study.kicker}</span>
									<strong>{study.metric}</strong>
								</div>
								<h3>{study.title}</h3>
								<p>{study.detail}</p>
								<small class="research-evidence">{study.evidence}</small>
							</article>
						))}
					</div>
					<aside class="research-source-note">
						<h3>Judge count note</h3>
						<p>
							The Hashnode Format Wars article currently names a three-judge LLM panel:
							Llama 4 Maverick, Claude Opus 4.6, and Atla Selene Mini. If the fourth
							referee model came from a later unpublished evaluation pass, it should be
							added once that artifact is attached so the public case study stays verifiable.
						</p>
					</aside>
				</section>

				<div class="section-subhead">
					<h3>Canonical articles</h3>
					<p>
						The full research writeups currently live on Hashnode. This page treats them
						as source evidence and connects them to the structured case-study template.
					</p>
				</div>
				<div class="article-grid">
					{promptTriageArticles.map((article) => (
						<article class="article-card">
							<span class="article-date">{article.date}</span>
							<h3>{article.title}</h3>
							<p>{article.description}</p>
							<a class="text-link" href={article.href} target="_blank" rel="noopener noreferrer">
								Read on Hashnode &rarr;
							</a>
						</article>
					))}
				</div>

				<div class="section-subhead">
					<h3>Research evidence gallery</h3>
					<p>
						Release assets from the PromptTriage repository are shown directly here so the
						case study has visible evidence instead of only outbound article links.
					</p>
				</div>
				<div class="research-gallery" aria-label="PromptTriage research chart assets">
					{researchAssets.map((asset) => (
						<article class="research-card">
							<button
								class="image-open"
								type="button"
								data-full-src={asset.src}
								data-full-alt={asset.alt}
								data-full-title={asset.title}
							>
								<img src={asset.src} alt={asset.alt} loading="lazy" />
								<span class="asset-label">{asset.label}</span>
								<h3>{asset.title}</h3>
							</button>
						</article>
					))}
				</div>

				<dialog class="image-modal" data-image-modal aria-label="Full-size PromptTriage research evidence image">
					<div class="modal-shell">
						<div class="modal-bar">
							<h3 data-modal-title>Research evidence</h3>

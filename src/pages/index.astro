---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HomeFolders from '../components/HomeFolders.jsx';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			body {
				background: #f7f8f8;
				color: #050505;
			}

			.landing-page {
				position: relative;
				width: 100%;
				max-width: none;
				min-height: 100vh;
				margin: 0;
				padding: 0;
				overflow: visible;
				background:
					linear-gradient(180deg, rgba(247, 248, 248, 0.72) 0%, rgba(247, 248, 248, 0.1) 44%, rgba(247, 248, 248, 0.86) 100%),
					url('/images/home/landing-grid.jpeg') center top / cover no-repeat;
			}

			.landing-page::before {
				content: '';
				position: absolute;
				inset: 0;
				pointer-events: none;
				background:
					radial-gradient(circle at 50% 45%, rgba(255, 255, 255, 0.34), transparent 31rem),
					linear-gradient(90deg, rgba(247, 248, 248, 0.54), transparent 22%, transparent 78%, rgba(247, 248, 248, 0.54));
				z-index: 0;
			}

			.home-hero {
				position: relative;
				z-index: 1;
				display: flex;
				min-height: 100vh;
				flex-direction: column;
				align-items: center;
				justify-content: flex-start;
				padding: clamp(5.35rem, 8vw, 6.8rem) 1rem calc(5rem + env(safe-area-inset-bottom));
				text-align: center;
			}

			.hero-kicker {
				margin: 0 0 0.85rem;
				font-size: 0.74rem;
				font-weight: 800;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: rgba(5, 5, 5, 0.58);
				opacity: 0;
				transform: translateY(12px);
				animation: heroIn 0.7s var(--ease-apple) forwards;
			}

			.hero-title {
				max-width: 15ch;
				margin: 0 auto 0.95rem;
				font-size: clamp(3.05rem, 7.3vw, 5.15rem);
				font-weight: 850;
				letter-spacing: 0;
				line-height: 0.92;
				color: #050505;
				text-wrap: balance;
				opacity: 0;
				transform: translateY(16px);
				animation: heroIn 0.85s var(--ease-apple) 0.08s forwards;
			}

			.hero-subtitle {
				max-width: 44rem;
				margin: 0 auto;
				color: rgba(5, 5, 5, 0.76);
				font-size: clamp(1rem, 3.8vw, 1.28rem);
				font-weight: 500;
				line-height: 1.45;
				text-wrap: balance;
				opacity: 0;
				transform: translateY(16px);
				animation: heroIn 0.85s var(--ease-apple) 0.16s forwards;
			}

			.terminal-shell {
				position: relative;
				isolation: isolate;
				width: min(100%, 54rem);
				margin: clamp(1.2rem, 3vw, 1.65rem) auto clamp(1.6rem, 3.5vw, 2rem);
				text-align: left;
				opacity: 0;
				transform: translateY(20px) scale(0.98);
				animation: terminalIn 0.9s var(--ease-apple) 0.28s forwards;
			}

			.terminal-shell::before {
				content: '';
				position: absolute;
				inset: -3.2rem -4.6rem -3.8rem;
				z-index: 0;
				background:
					radial-gradient(ellipse at 24% 72%, rgba(147, 119, 255, 0.38), transparent 46%),
					radial-gradient(ellipse at 76% 70%, rgba(165, 205, 255, 0.34), transparent 50%),
					radial-gradient(ellipse at 50% 52%, rgba(255, 255, 255, 0.78), transparent 57%);
				filter: blur(22px) saturate(1.08);
				opacity: 0.9;
				pointer-events: none;
				transform: translate3d(-1.2rem, 0.25rem, 0) scale(0.98);
				animation: terminalGlow 7.5s ease-in-out infinite alternate;
			}

			.terminal-shell::after {
				content: '';
				position: absolute;
				inset: -1px;
				z-index: 1;
				border-radius: 1.35rem;
				background: linear-gradient(145deg, rgba(255, 255, 255, 0.48), rgba(0, 0, 0, 0.28));
				filter: blur(0.4px);
				pointer-events: none;
			}

			.terminal {
				position: relative;
				z-index: 2;
				height: clamp(23rem, 30vw, 25.5rem);
				overflow: hidden;
				border: 1px solid rgba(255, 255, 255, 0.16);
				border-radius: 1.25rem;
				background: #000000;
				box-shadow:
					0 1.5rem 4.5rem rgba(0, 0, 0, 0.22),
					0 0 0 1px rgba(255, 255, 255, 0.06) inset;
				color: #f2f2f2;
				font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
			}

			.terminal-bar {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				align-items: center;
				gap: 1rem;
				padding: 0.85rem 1rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025));
			}

			.window-controls {
				display: flex;
				gap: 0.48rem;
				justify-self: start;
			}

			.window-controls span {
				width: 0.72rem;
				height: 0.72rem;
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.42);
				box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.2) inset;
			}

			.window-controls span:nth-child(1) {
				background: #ff5f57;
			}

			.window-controls span:nth-child(2) {
				background: #febc2e;
			}

			.window-controls span:nth-child(3) {
				background: #28c840;
			}

			.terminal-title {
				justify-self: center;
				font-size: 0.76rem;
				font-weight: 700;
				letter-spacing: 0;
				color: rgba(255, 255, 255, 0.68);
			}

			.terminal-body {
				display: flex;
				height: calc(100% - 3.2rem);
				flex-direction: column;
				justify-content: flex-start;
				gap: 0.55rem;
				overflow-y: auto;
				padding: clamp(1rem, 3.5vw, 1.35rem);
				scrollbar-color: rgba(0, 255, 65, 0.32) transparent;
				scrollbar-width: thin;
			}

			.terminal-lines {
				display: flex;
				flex: 0 0 auto;
				flex-direction: column;
				gap: 0.42rem;
				min-height: 0;
				overflow: visible;
			}

			:global(.terminal-line) {
				display: block;
				min-height: 0;
				color: rgba(233, 236, 239, 0.86);
				font-size: clamp(0.76rem, 2.1vw, 0.88rem);
				line-height: 1.45;
				white-space: pre-wrap;
				word-break: break-word;
			}

			:global(.terminal-line.command) {
				color: #ffffff;
			}

			:global(.terminal-prompt-user) {
				color: #00ff41;
				font-weight: 700;
			}

			:global(.terminal-prompt-path) {
				color: #4f7dff;
				font-weight: 700;
			}

			:global(.terminal-prompt-dollar),
			:global(.terminal-command-text) {
				color: #f2f2f2;
			}

			:global(.terminal-line.success) {
				color: #00ff41;
			}

			:global(.terminal-line.note) {
				color: #f2f2f2;
			}

			:global(.terminal-line.dim) {
				color: #9ca3af;
			}

			:global(.terminal-line.warn) {
				color: #ffff66;
			}

			:global(.terminal-cursor) {
				display: inline-block;
				width: 0.58rem;
				height: 1em;
				margin-left: 0.2rem;
				vertical-align: -0.12em;
				background: #f7f7f7;
				animation: blink 1s steps(2, start) infinite;
			}

			.terminal-menu {
				display: grid;
				width: 100%;
				gap: 0;
				margin-top: 0.15rem;
				padding-top: 0;
				border-top: 0;
				outline: none;
			}

			.terminal-menu[hidden] {
				display: none;
			}

			:global(.terminal-menu-help) {
				display: block;
				margin: 0 0 0.26rem;
				color: #f2f2f2;
				font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
				font-size: clamp(0.72rem, 2.2vw, 0.82rem);
				line-height: 1.4;
			}

			:global(.terminal-menu-hint) {
				display: block;
				margin-top: 0.48rem;
				color: #9ca3af;
				font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
				font-size: clamp(0.72rem, 2.2vw, 0.82rem);
				line-height: 1.35;
			}

			:global(.terminal-option) {
				display: grid;
				width: 100%;
				grid-template-columns: 1.35rem 1fr;
				gap: 0.28rem;
				align-items: start;
				border: 0;
				border-radius: 0.35rem;
				background: transparent;
				color: #f2f2f2;
				cursor: pointer;
				font: inherit;
				font-size: clamp(0.76rem, 2.1vw, 0.86rem);
				line-height: 1.35;
				padding: 0.16rem 0.25rem;
				text-align: left;
				transition:
					background 0.16s ease,
					color 0.16s ease;
			}

			:global(.terminal-option:hover),
			:global(.terminal-option.is-selected) {
				background: #5f8f65;
				color: #ffffff;
			}

			:global(.terminal-option:focus-visible) {
				outline: 1px solid #00ff41;
				outline-offset: 2px;
			}

			:global(.terminal-option-marker) {
				color: #f2f2f2;
				font-weight: 800;
				line-height: 1.35;
			}

			:global(.terminal-option-command) {
				color: #f2f2f2;
				font-weight: 700;
			}

			:global(.terminal-option-desc) {
				color: #d9d9d9;
				font-weight: 500;
			}

			:global(.terminal-option.is-selected .terminal-option-desc),
			:global(.terminal-option:hover .terminal-option-desc) {
				color: #ffffff;
			}

			.quick-links {
				display: grid;
				width: min(100%, 58rem);
				grid-template-columns: 1fr;
				gap: 0.85rem;
				opacity: 0;
				transform: translateY(20px);
				animation: heroIn 0.85s var(--ease-apple) 0.42s forwards;
			}

			.quick-card {
				position: relative;
				display: grid;
				min-height: 11.5rem;
				align-content: start;
				gap: 0.9rem;
				overflow: hidden;
				border: 1px solid rgba(255, 255, 255, 0.72);
				border-radius: 1.55rem;
				background: rgba(255, 255, 255, 0.74);
				box-shadow:
					0 1.2rem 3rem rgba(15, 23, 42, 0.08),
					0 1px 0 rgba(255, 255, 255, 0.9) inset;
				backdrop-filter: blur(22px);
				-webkit-backdrop-filter: blur(22px);
				color: #050505;
				padding: 1.35rem;
				text-align: left;
				transition:
					transform 0.28s var(--ease-apple),
					background 0.28s var(--ease-apple),
					border-color 0.28s var(--ease-apple),
					box-shadow 0.28s var(--ease-apple);
			}

			.quick-card::after {
				content: '';
				position: absolute;
				inset: 0;
				pointer-events: none;
				background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), transparent 42%);
				opacity: 0;
				transition: opacity 0.28s var(--ease-apple);
			}

			.quick-card:hover,
			.quick-card:focus-visible {
				transform: translateY(-6px);
				border-color: rgba(5, 5, 5, 0.14);
				background: rgba(255, 255, 255, 0.88);
				box-shadow:
					0 1.5rem 3.6rem rgba(15, 23, 42, 0.14),
					0 1px 0 rgba(255, 255, 255, 0.92) inset;
			}

			.quick-card:hover::after,
			.quick-card:focus-visible::after {
				opacity: 1;
			}

			.quick-icon {
				position: relative;
				z-index: 1;
				display: grid;
				width: 2.7rem;
				height: 2.7rem;
				place-items: center;
				border: 1px solid rgba(0, 0, 0, 0.08);
				border-radius: 0.9rem;
				background: rgba(255, 255, 255, 0.9);
				box-shadow: 0 0.7rem 1.5rem rgba(15, 23, 42, 0.08);
				color: #050505;
			}

			.quick-card h2 {
				position: relative;
				z-index: 1;
				margin: 0;
				font-size: 1.18rem;
				letter-spacing: 0;
				color: #050505;
			}

			.quick-card p {
				position: relative;
				z-index: 1;
				margin: 0;
				color: rgba(5, 5, 5, 0.76);
				font-size: 0.94rem;
				line-height: 1.42;
			}

			.quick-card span {
				position: relative;
				z-index: 1;
				margin-top: auto;
				color: rgba(5, 5, 5, 0.72);
				font-size: 0.83rem;
				font-weight: 850;
			}

			.quick-card span::after {
				content: ' ->';
				display: inline-block;
				transition: transform 0.22s var(--ease-apple);
			}

			.quick-card:hover span::after,
			.quick-card:focus-visible span::after {
				transform: translateX(4px);
			}

			[data-mode="dark"] body {
				background: #050505;
				color: #ffffff;
			}

			[data-mode="dark"] .landing-page {
				background:
					linear-gradient(180deg, rgba(5, 5, 5, 0.66) 0%, rgba(5, 5, 5, 0.48) 46%, rgba(5, 5, 5, 0.88) 100%),
					url('/images/home/landing-grid.jpeg') center top / cover no-repeat;
			}

			[data-mode="dark"] .landing-page::before {
				background:
					radial-gradient(circle at 50% 45%, rgba(255, 255, 255, 0.12), transparent 30rem),
					linear-gradient(90deg, rgba(5, 5, 5, 0.68), transparent 20%, transparent 80%, rgba(5, 5, 5, 0.68));
			}

			[data-mode="dark"] .hero-title {
				color: #ffffff;
			}

			[data-mode="dark"] .hero-kicker,
			[data-mode="dark"] .hero-subtitle {
				color: rgba(255, 255, 255, 0.78);
			}

			[data-mode="dark"] .quick-card {
				border-color: rgba(255, 255, 255, 0.12);
				background: rgba(12, 12, 13, 0.72);
				box-shadow:
					0 1.4rem 3.5rem rgba(0, 0, 0, 0.42),
					0 1px 0 rgba(255, 255, 255, 0.08) inset;
				color: #ffffff;
			}

			[data-mode="dark"] .quick-card:hover,
			[data-mode="dark"] .quick-card:focus-visible {
				border-color: rgba(255, 255, 255, 0.22);
				background: rgba(18, 18, 20, 0.84);
			}

			[data-mode="dark"] .quick-icon {
				border-color: rgba(255, 255, 255, 0.12);
				background: rgba(255, 255, 255, 0.08);
				color: #ffffff;
			}

			[data-mode="dark"] .quick-card h2 {
				color: #ffffff;
			}

			[data-mode="dark"] .quick-card p,
			[data-mode="dark"] .quick-card span {
				color: rgba(255, 255, 255, 0.76);
			}

			@keyframes heroIn {
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes terminalIn {
				to {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}

			@keyframes terminalGlow {
				0% {
					opacity: 0.72;
					transform: translate3d(-1.8rem, 0.65rem, 0) scale(0.98);
				}

				48% {
					opacity: 1;
					transform: translate3d(1.15rem, -0.35rem, 0) scale(1.04);
				}

				100% {
					opacity: 0.82;
					transform: translate3d(1.65rem, 0.5rem, 0) scale(1);
				}
			}

			@keyframes blink {
				0%,
				42% {
					opacity: 1;
				}
				43%,
				100% {
					opacity: 0;
				}
			}

			@media (min-width: 720px) {
				.home-hero {
					padding-inline: 1.5rem;
				}

				.quick-links {
					grid-template-columns: repeat(2, minmax(0, 1fr));
					gap: 1rem;
				}
			}

			@media (min-width: 1080px) {
				.home-hero {
					padding-top: 6.35rem;
				}

				.quick-links {
					grid-template-columns: repeat(4, minmax(0, 1fr));
				}
			}

			@media (max-width: 520px) {
				.home-hero {
					padding-top: 5.45rem;
				}

				.hero-title {
					max-width: 10.5ch;
				}

				.terminal-bar {
					align-items: flex-start;
				}

				.terminal {
					height: 27rem;
				}

				.terminal-title {
					display: none;
				}

				.terminal-menu {
					gap: 0.14rem;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.hero-kicker,
				.hero-title,
				.hero-subtitle,
				.terminal-shell,
				.quick-links {
					opacity: 1;
					transform: none;
					animation: none;
				}

				.terminal-shell::before {
					animation: none;
					transform: none;
				}

				:global(.terminal-cursor) {
					animation: none;
				}
			}
		</style>
	</head>
	<body data-theme="clean">
		<Header />

		<main class="landing-page">
			<section class="home-hero" aria-labelledby="home-title">
				<p class="hero-kicker">Kristofer Jussmann</p>
				<h1 id="home-title" class="hero-title">Technical Product Studio & Blog</h1>
				<p class="hero-subtitle">
					Building agentic systems, robust automation, and minimal software. Documenting the engineering path from
					research prototypes to deployable products.
				</p>

				<div class="terminal-shell" aria-label="Interactive site terminal">
					<div class="terminal">
						<div class="terminal-bar">
							<div class="window-controls" aria-hidden="true"><span></span><span></span><span></span></div>
							<div class="terminal-title">portfolio-session</div>
						</div>
						<div class="terminal-body">
							<div class="terminal-lines" aria-live="polite" data-terminal-lines></div>
							<div
								class="terminal-menu"
								role="listbox"
								tabindex="0"
								aria-label="Terminal command menu"
								data-terminal-menu
							>
								<span class="terminal-menu-help">Select a section:</span>
								<span class="terminal-menu-hint">Use Up/Down and Enter. Tap a section on mobile.</span>
							</div>
						</div>
					</div>
				</div>

				<HomeFolders client:load />
			</section>
		</main>

		<Footer />

		<script>
			const terminalLines = document.querySelector('[data-terminal-lines]');
			const terminalMenu = document.querySelector('[data-terminal-menu]');

			const menuOptions = [
				{
					key: 'work',
					command: 'work --current',
					label: 'Current work',
				},
				{
					key: 'case-studies',
					command: 'cases --evidence',
					label: 'Studies',
				},
				{
					key: 'stack',
					command: 'stack --systems',
					label: 'Systems stack',
				},
				{
					key: 'contact',
					command: 'contact --signals',
					label: 'Public links',
				},
			];

			const commandSets = {
				intro: [
					{ type: 'command', text: 'whoami --brief' },
					{ type: 'note', text: 'Kristofer Jussmann - building technical products, AI infrastructure, automation workflows, and evidence-backed project documentation.' },
					{ type: 'command', text: 'status --active-projects' },
					{ type: 'success', text: 'ok: PromptTriage, Kaelux.dev, ViperMesh, n8n workflows, and lab projects indexed for reviewer-friendly navigation.' },
				],
				work: [
					{ type: 'command', text: 'work --current' },
					{ type: 'success', text: 'focus: secure AI infrastructure, agent workflows, production automation, and clean technical storytelling.' },
					{ type: 'note', text: 'goal: help hiring managers get fast context first, then deeper evidence when they want it.' },
				],
				'case-studies': [
					{ type: 'command', text: 'case-studies --evidence' },
					{ type: 'success', text: 'found: PromptTriage complete page with prompt corpus research, format evals, cloud costs, architecture, and tradeoffs.' },
					{ type: 'warn', text: 'next: Kaelux.dev, ViperMesh, and n8n-workflows get structured studies as source evidence is assembled.' },
				],
				stack: [
					{ type: 'command', text: 'stack --systems' },
					{ type: 'success', text: 'stack: Astro, React, Supabase, Stripe, FastAPI, RAG pipelines, Azure ML, containers, automation systems.' },
					{ type: 'dim', text: 'trace: production notes and failure modes stay visible instead of being hidden behind polished summaries.' },
				],
				contact: [
					{ type: 'command', text: 'contact --signals' },
					{ type: 'success', text: 'links: GitHub @Ker102, LinkedIn Kristofer Jussmann, Kaelux.dev company page.' },
					{ type: 'note', text: 'ready: use the navbar, cards, or this terminal menu to move from summary to evidence.' },
				],
			};

			const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			let activeRun = 0;
			let selectedOption = 0;
			let isTyping = false;

			const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

			function addLine(type) {
				const line = document.createElement('span');
				line.className = `terminal-line ${type}`;

				if (type === 'command') {
					line.innerHTML =
						'<span class="terminal-prompt-user">guest@kristofer.dev</span><span class="terminal-prompt-path">:~</span><span class="terminal-prompt-dollar">$</span> ';
					const commandText = document.createElement('span');
					commandText.className = 'terminal-command-text';
					line.appendChild(commandText);
					terminalLines?.appendChild(line);
					return commandText;
				}

				terminalLines?.appendChild(line);
				return line;
			}

			function renderMenu() {
				if (!terminalMenu) return;

				terminalMenu.innerHTML = '<span class="terminal-menu-help">Select a section:</span>';
				menuOptions.forEach((option, index) => {
					const row = document.createElement('button');
					row.type = 'button';
					row.className = `terminal-option${index === selectedOption ? ' is-selected' : ''}`;
					row.setAttribute('role', 'option');
					row.setAttribute('aria-selected', index === selectedOption ? 'true' : 'false');
					row.dataset.command = option.key;
					row.innerHTML = `
						<span class="terminal-option-marker">${index === selectedOption ? '>' : ' '}</span>
						<span>
							<span class="terminal-option-command">${index + 1}. ${option.command}</span>
							<span class="terminal-option-desc"> - ${option.label}</span>
						</span>
					`;
					row.addEventListener('mouseenter', () => {
						selectedOption = index;
						renderMenu();
					});
					row.addEventListener('click', () => {
						selectedOption = index;
						runSelectedOption();
					});
					terminalMenu.appendChild(row);
				});
				terminalMenu.insertAdjacentHTML(
					'beforeend',
					'<span class="terminal-menu-hint">Use Up/Down and Enter. Tap a section on mobile.</span>',
				);
			}

			function moveSelection(offset) {
				selectedOption = (selectedOption + offset + menuOptions.length) % menuOptions.length;
				renderMenu();
			}

			function runSelectedOption() {
				if (isTyping) return;
				const option = menuOptions[selectedOption];
				playTerminal(option.key);
			}

			async function typeText(line, text, runId) {
				if (reducedMotion) {
					line.textContent = text;
					return;
				}

				for (let index = 0; index <= text.length; index += 1) {
					if (runId !== activeRun) return;
					line.textContent = text.slice(0, index);
					await sleep(index < 16 ? 6 : 2);
				}
			}

			async function playTerminal(key = 'intro') {
				if (!terminalLines) return;
				activeRun += 1;
				const runId = activeRun;
				isTyping = true;
				terminalLines.innerHTML = '';
				if (terminalMenu) terminalMenu.hidden = true;

				const lines = commandSets[key] || commandSets.intro;
				for (const item of lines) {
					if (runId !== activeRun) return;
					const line = addLine(item.type);
					await typeText(line, item.text, runId);
					await sleep(reducedMotion ? 0 : item.type === 'command' ? 70 : 90);
				}

				if (runId === activeRun) {
					const prompt = addLine('command');
					prompt.innerHTML = 'select <span class="terminal-cursor" aria-hidden="true"></span>';
					isTyping = false;
					if (terminalMenu) terminalMenu.hidden = false;
					renderMenu();
					terminalMenu?.focus({ preventScroll: true });
				}
			}

			terminalMenu?.addEventListener('keydown', (event) => {
				if (event.key === 'ArrowDown') {
					event.preventDefault();
					moveSelection(1);
				}

				if (event.key === 'ArrowUp') {
					event.preventDefault();
					moveSelection(-1);
				}

				if (event.key === 'Enter') {
					event.preventDefault();
					runSelectedOption();
				}
			});

			renderMenu();
			playTerminal('intro');
		</script>
	</body>
</html>

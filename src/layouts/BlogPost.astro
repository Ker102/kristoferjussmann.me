---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { PERSON_HANDLE, PERSON_KNOWS_ABOUT, PERSON_NAME, PERSON_SAME_AS } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, externalUrl, source } = Astro.props;
const personId = 'https://ker102blog.vercel.app/about/#kristofer-jussmann-ker102';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline: title,
				description: description,
				datePublished: pubDate.toISOString(),
				...(updatedDate && { dateModified: updatedDate.toISOString() }),
				author: {
					'@type': 'Person',
					'@id': personId,
					name: PERSON_NAME,
					alternateName: PERSON_HANDLE,
					url: 'https://ker102blog.vercel.app/about/',
					sameAs: PERSON_SAME_AS,
					knowsAbout: PERSON_KNOWS_ABOUT,
				},
				publisher: {
					'@type': 'Person',
					'@id': personId,
					name: PERSON_NAME,
				},
				mainEntityOfPage: {
					'@type': 'WebPage',
					'@id': Astro.url.href,
				},
			})}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding-top: 6rem;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: clamp(2rem, 8vw, 3.5rem);
				line-height: 1.05;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			/* External source banner */
			.external-banner {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				padding: 0.875rem 1.25rem;
				margin: 1.5rem 0;
				background: linear-gradient(135deg, rgba(37, 99, 235, 0.08), rgba(99, 102, 241, 0.08));
				border: 1px solid rgba(99, 102, 241, 0.2);
				border-radius: 10px;
				font-size: 0.95rem;
			}
			.external-banner .source-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.25rem 0.65rem;
				background: linear-gradient(135deg, #2563eb, #6366f1);
				color: white;
				border-radius: 20px;
				font-size: 0.8rem;
				font-weight: 600;
				text-transform: capitalize;
				letter-spacing: 0.02em;
				white-space: nowrap;
			}
			.external-banner a {
				color: #2563eb;
				font-weight: 600;
				text-decoration: none;
				transition: color 0.2s;
			}
			.external-banner a:hover {
				color: #6366f1;
				text-decoration: underline;
			}

			.prose :global(pre) {
				max-width: 100%;
				overflow-x: auto;
			}

			.prose :global(code) {
				overflow-wrap: anywhere;
				word-break: break-word;
			}

			@media (max-width: 720px) {
				main {
					width: 100%;
					padding-top: 5.75rem;
				}

				.prose {
					width: 100%;
					max-width: 100%;
					padding: 1rem;
				}

				.title {
					padding: 0.75rem 0 1rem;
					text-align: left;
				}

				.title h1 {
					font-size: clamp(2rem, 10vw, 2.75rem);
				}

				.hero-image {
					padding: 0 1rem;
				}

				.external-banner {
					align-items: flex-start;
					flex-direction: column;
					padding: 0.9rem;
				}

				.external-banner .source-badge {
					white-space: normal;
				}

				.prose :global(pre),
				.prose :global(pre code),
				.prose :global(pre span) {
					white-space: pre-wrap !important;
					word-break: break-all;
				}

				.prose :global(pre span.line) {
					display: block;
					max-width: 100%;
				}

				.prose :global(pre span.line span) {
					display: inline;
				}

				.prose :global(:not(pre) > code) {
					white-space: normal;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					{externalUrl && (
						<div class="external-banner">
							{source && <span class="source-badge">📝 {source}</span>}
							<span>
								Originally published on <a href={externalUrl} target="_blank" rel="noopener noreferrer">{source || 'external site'}</a> — <a href={externalUrl} target="_blank" rel="noopener noreferrer">Read the full article →</a>
							</span>
						</div>
					)}
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

